# Auth backend (BetterAuth) — required for the api/* serverless functions and
# the local dev/check scripts. Copy to `.env` and fill in real values.

# Neon Postgres connection string (or any Postgres). On Vercel, set this in the
# project's Environment Variables. Locally, point it at your dev Postgres.
DATABASE_URL=postgres://user:pass@host/dbname?sslmode=require

# Secret used to sign sessions + tokens. Generate one with:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-openssl-rand-base64-32

# Public origin of the auth server. On Vercel this is your site URL.
# Locally the dev server defaults to http://localhost:3000 if unset.
BETTER_AUTH_URL=https://cuecards.cc
